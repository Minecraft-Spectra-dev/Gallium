{
	"schemaVersion": 1,
	"id": "gallium",
	"version": "${version}",
	"name": "Gallium",
	"description": "Client-side enhancements: glow outline for held items, resource pack utilities.",
	"authors": [
		"Spectra"
	],
	"license": "CC0-1.0",
	"icon": "assets/gallium/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"cn.spectra.gallium.Gallium"
		],
		"sodium:config_api_user": [
			"cn.spectra.gallium.compat.sodium.GalliumSodiumConfig"
		]
	},
	"mixins": [
		"gallium.mixins.json",
		"gallium-glowoutline.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}